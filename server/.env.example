# DogeRat Server Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID (required - the ID where you want to receive messages)
TELEGRAM_CHAT_ID=

# Server port (optional, default: 8999)
PORT=8999

# Ping address for keep-alive (optional)
PING_ADDRESS=https://www.google.com
